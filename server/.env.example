PORT=4000
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret

# Optional free local LLM. Install Ollama and pull llama3.1:8b or mistral.
# Without Ollama, the app uses the built-in same-language offline fallback.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Optional: change how many subject responses are collected before auto-ending.
MAX_INTERROGATION_RESPONSES=8
